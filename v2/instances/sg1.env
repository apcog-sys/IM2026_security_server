# Security Gateway — instance SG1 (cluster A).
# Same software as SG2; only the instance identity / DB / ports differ.
# "consumer" vs "provider" is NOT fixed here - it depends on what gets
# registered on this instance at runtime (it can host both).
IM_INSTANCE=GOVSTACK
SG_GATEWAY_CODE=SG1
SG_DB_NAME=sgateway_sg1_db
SG_PORT=8081
SG_MESSAGE_PORT=8443
SG_ADDRESS=https://127.0.0.1:8443
SG_MTLS=true
SG_OWNER_CLASS=GOV
SG_OWNER_CODE=1001
SG_OWNER_NAME=Ministry of Digital Affairs
SG_TITLE=Security Gateway SG1 (cluster A)
