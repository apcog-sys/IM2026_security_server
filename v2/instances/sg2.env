# Security Gateway — instance SG2 (cluster B).
# Same software as SG1; only the instance identity / DB / ports differ.
# "consumer" vs "provider" is NOT fixed here - it depends on what gets
# registered on this instance at runtime (it can host both).
IM_INSTANCE=GOVSTACK
SG_GATEWAY_CODE=SG2
SG_DB_NAME=sgateway_sg2_db
SG_PORT=8082
SG_MESSAGE_PORT=8444
SG_ADDRESS=https://127.0.0.1:8444
SG_MTLS=true
SG_OWNER_CLASS=GOV
SG_OWNER_CODE=2001
SG_OWNER_NAME=Population Registry Agency
SG_TITLE=Security Gateway SG2 (cluster B)
